{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.;Initial Catalog=EduPlatform2;Integrated Security=True;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_A_256BIT_RANDOM_KEY_IN_PRODUCTION_USE_ENV_VARIABLE",
